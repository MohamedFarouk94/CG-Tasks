{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Active File",
            "type": "shell",
            "command": "gcc",
            "args": [
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-lGL", "-lGLU", "-lglut", "-lm"
            ],
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run Active File",
            "type": "shell",
            "command": "${fileDirname}/${fileBasenameNoExtension}",
            "dependsOn": "Build Active File",
            "options": {
                "env": {
                    "DISPLAY": ":1"
                }
            },
            "group": "test"
        },
        {
            "label": "Build & Run Active File",
            "type": "shell",
            "command": "gcc ${file} -o ${fileDirname}/${fileBasenameNoExtension} -lGL -lGLU -lglut -lm && DISPLAY=:1 ${fileDirname}/${fileBasenameNoExtension}",
            "group": "test",
            "problemMatcher": ["$gcc"]
        }
    ]
}