{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build CG_Lab1",
            "type": "shell",
            "command": "gcc",
            "args": [
                "${workspaceFolder}/CG_Lab1.c",
                "-o",
                "${workspaceFolder}/CG_Lab1",
                "-lGL", "-lGLU", "-lglut", "-lm"
            ],
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run CG_Lab1",
            "type": "shell",
            "command": "${workspaceFolder}/CG_Lab1",
            "dependsOn": "Build CG_Lab1",
            "options": {
                "env": {
                    "DISPLAY": ":1"
                }
            },
            "group": "test"
        }
    ]
}